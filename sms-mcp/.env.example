# Dial API key (sk_live_...). The send_sms tool sends from your Dial number.
DIAL_API_KEY=
# Port the MCP server listens on locally.
PORT=8787
# Override only for self-hosted Dial.
# DIAL_BASE_URL=https://getdial.ai

# Stripe TEST key (sk_test_...). Optional — only needed for send_payment_request.
STRIPE_API_KEY=
# Where the Stripe checkout page redirects after pay/cancel.
STRIPE_SUCCESS_URL=https://example.com/paid

# Optional Dial number id the webhook tools (/tools/sms, /tools/payment) send
# FROM for non-Dial agents (e.g. an ElevenLabs AUT). Defaults to the account's
# first Dial number. Real delivery is best-effort; the self-log is the evidence.
SMS_FROM_NUMBER_ID=
