{
  "name": "dial-sms-mcp",
  "version": "1.0.0",
  "description": "Context MCP server exposing a send_sms tool so a Dial voice agent can text callers mid-call.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "tunnel": "ngrok http 8787 --log=stdout",
    "start:tunnel": "bash start.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
