{
	"compilerOptions": {
		"module": "nodenext",
		"target": "esnext",
		"types": ["node"],
		"sourceMap": true,
		"noUncheckedIndexedAccess": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"noEmit": true
	}
}
